<section class="section section--alt" id="discografia" aria-label="Discografia">
  <div class="wrap">
    <span class="label">Discografia</span>
    <div class="albums">

      <!-- Aurora album article -->
      <article aria-label="Álbum Aurora, 2016">
        <div class="album__cover" style="background: #E8E5DC;">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <!-- Celestial navigation dial -->
            <circle cx="100" cy="100" r="88" fill="none" stroke="#2A2E2C" stroke-width="0.5"/>
            <!-- Cardinal ticks -->
            <line x1="100" y1="7"   x2="100" y2="23"  stroke="#2A2E2C" stroke-width="0.9"/>
            <line x1="100" y1="177" x2="100" y2="193" stroke="#2A2E2C" stroke-width="0.9"/>
            <line x1="7"   y1="100" x2="23"  y2="100" stroke="#2A2E2C" stroke-width="0.9"/>
            <line x1="177" y1="100" x2="193" y2="100" stroke="#2A2E2C" stroke-width="0.9"/>
            <!-- Intermediate ticks -->
            <line x1="143" y1="21"  x2="136" y2="33"  stroke="#2A2E2C" stroke-width="0.4"/>
            <line x1="179" y1="57"  x2="167" y2="64"  stroke="#2A2E2C" stroke-width="0.4"/>
            <line x1="179" y1="143" x2="167" y2="136" stroke="#2A2E2C" stroke-width="0.4"/>
            <line x1="143" y1="179" x2="136" y2="167" stroke="#2A2E2C" stroke-width="0.4"/>
            <line x1="57"  y1="179" x2="64"  y2="167" stroke="#2A2E2C" stroke-width="0.4"/>
            <line x1="21"  y1="143" x2="33"  y2="136" stroke="#2A2E2C" stroke-width="0.4"/>
            <line x1="21"  y1="57"  x2="33"  y2="64"  stroke="#2A2E2C" stroke-width="0.4"/>
            <line x1="57"  y1="21"  x2="64"  y2="33"  stroke="#2A2E2C" stroke-width="0.4"/>
            <!-- Quadrant dashed lines -->
            <line x1="100" y1="12" x2="100" y2="188" stroke="#2A2E2C" stroke-width="0.2" stroke-dasharray="1.5,9"/>
            <line x1="12"  y1="100" x2="188" y2="100" stroke="#2A2E2C" stroke-width="0.2" stroke-dasharray="1.5,9"/>
            <!-- Inner dashed ring -->
            <circle cx="100" cy="100" r="54" fill="none" stroke="#2A2E2C" stroke-width="0.2" stroke-dasharray="2,7"/>
            <!-- Centre crosshair -->
            <circle cx="100" cy="100" r="7"  fill="none" stroke="#2A2E2C" stroke-width="0.5"/>
            <line x1="93" y1="100" x2="107" y2="100" stroke="#2A2E2C" stroke-width="0.5"/>
            <line x1="100" y1="93" x2="100" y2="107" stroke="#2A2E2C" stroke-width="0.5"/>
            <!-- Roman numerals -->
            <text x="93"  y="33"  font-size="7" fill="#5A6058" font-family="serif">XII</text>
            <text x="174" y="104" font-size="7" fill="#5A6058" font-family="serif">III</text>
            <text x="91"  y="175" font-size="7" fill="#5A6058" font-family="serif">VI</text>
            <text x="10"  y="104" font-size="7" fill="#5A6058" font-family="serif">IX</text>
            <!-- Decorative arc fragments -->
            <path d="M 46 54 Q 100 30 154 54" fill="none" stroke="#8A9E9A" stroke-width="0.3" opacity="0.5"/>
            <path d="M 154 146 Q 100 170 46 146" fill="none" stroke="#8A9E9A" stroke-width="0.3" opacity="0.5"/>
          </svg>
        </div>
        <h2 class="album__title">Aurora</h2>
        <p class="album__meta">
          2016 · Tradisom Produções Culturais<br>
          Mix &amp; master: Tó Pinheiro da Silva<br>
          Artwork: Duck.Production
        </p>
        <a href="https://criaturapt.bandcamp.com/album/aurora" class="album__link" target="_blank" rel="noopener">
          Ouvir no Bandcamp →
        </a>
      </article>

      <!-- Bem Bonda album article -->
      <article aria-label="Álbum Bem Bonda, 2021">
        <div class="album__cover" style="background: #D8D4CE;">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <clipPath id="stone-clip">
                <polygon points="78,38 116,31 143,54 153,88 149,127 123,153 88,159 60,141 44,112 50,77"/>
              </clipPath>
            </defs>
            <!-- Mineral strata -->
            <rect x="40" y="28"  width="130" height="23" fill="#8888A0" clip-path="url(#stone-clip)"/>
            <rect x="40" y="51"  width="130" height="28" fill="#C07840" clip-path="url(#stone-clip)"/>
            <rect x="40" y="79"  width="130" height="26" fill="#445088" clip-path="url(#stone-clip)"/>
            <rect x="40" y="105" width="130" height="24" fill="#884420" clip-path="url(#stone-clip)"/>
            <rect x="40" y="129" width="130" height="34" fill="#ADAAA2" clip-path="url(#stone-clip)"/>
            <!-- Stone outline -->
            <polygon points="78,38 116,31 143,54 153,88 149,127 123,153 88,159 60,141 44,112 50,77"
                     fill="none" stroke="#9A9690" stroke-width="0.7"/>
          </svg>
        </div>
        <h2 class="album__title">Bem Bonda</h2>
        <p class="album__meta">
          2021 · Omnichord Records<br>
          Mix &amp; master: António Pinheiro da Silva<br>
          Artwork: Catherina Cardoso &amp; João Catarino
        </p>
        <a href="https://criaturapt.bandcamp.com/album/bem-bonda" class="album__link" target="_blank" rel="noopener">
          Ouvir no Bandcamp →
        </a>
        <button class="pedra-btn" id="pedra-btn" aria-expanded="false" aria-controls="pedra-panel">
          A Pedra-Pão →
        </button>
      </article>

      <!-- Pedra-Pão panel — spans full width -->
      <div class="pedra-panel" id="pedra-panel" role="region" aria-label="A história da Pedra-Pão">
        <span class="label" style="margin-bottom: 1.25rem;">A Pedra-Pão</span>
        <div class="pedra-inner">
          <div class="pedra-cover" style="background: #F0EAD8;">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <defs>
                <clipPath id="bread-clip">
                  <polygon points="75,42 118,35 146,57 156,90 151,129 124,156 87,162 59,143 43,115 49,80"/>
                </clipPath>
              </defs>
              <!-- Bread strata -->
              <rect x="38" y="32"  width="132" height="24" fill="#7A4A82" clip-path="url(#bread-clip)"/>
              <rect x="38" y="56"  width="132" height="28" fill="#C86820" clip-path="url(#bread-clip)"/>
              <rect x="38" y="84"  width="132" height="26" fill="#C89818" clip-path="url(#bread-clip)"/>
              <rect x="38" y="110" width="132" height="24" fill="#882840" clip-path="url(#bread-clip)"/>
              <rect x="38" y="134" width="132" height="32" fill="#C8A060" clip-path="url(#bread-clip)"/>
              <!-- Bread outline -->
              <polygon points="75,42 118,35 146,57 156,90 151,129 124,156 87,162 59,143 43,115 49,80"
                       fill="none" stroke="#9A7840" stroke-width="0.8"/>
            </svg>
          </div>
          <div>
            <p class="pedra-text">
              A pedra da capa foi recolhida na Mina de São Domingos, no Alentejo,
              após um concerto em Serpa. O artista Diogo Vaz Cavaleiro transformou-a
              num pão na Padaria Natural Peter Pão, no Fundão.
            </p>
            <p class="pedra-text">
              Pigmentos naturais — batata-doce roxa, beterraba e açafrão da índia —
              recriam as camadas coloridas da pedra original. Enviado aos membros do
              Bando como objecto de arte, com um código para ouvir o disco.
            </p>
            <p class="pedra-lyric">
              «Bem Bonda o pão que está caro,<br>
              quanto mais a fome.»
            </p>
          </div>
        </div>
      </div>

    </div>

    <p class="arc-note">
      De céu a terra —<br>de Aurora ao chão do Bem Bonda.
    </p>
  </div>
</section>
