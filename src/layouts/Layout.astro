    <style is:global>
/* ─── RESET ─────────────────────────────────────────────── */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
a { text-decoration: none; color: inherit; }
button { cursor: pointer; border: none; background: none; padding: 0; font: inherit; }
img { display: block; max-width: 100%; }

/* ─── TOKENS ─────────────────────────────────────────────── */
:root {
  --bg-void:     #120F0D;
  --bg-deep:     #1A1713;
  --bg-earth:    #2C2820;
  --bg-surface:  #231F1A;
  --parchment:   #D8D0BE;
  --muted:       #5A4E3E;
  --faint:       #3A3028;
  --ghost:       #251E18;
  --amber:       #C07840;
  --violet:      #8888A0;
  --rust:        #884420;
  --blue:        #445088;
  --font-serif:  'EB Garamond', Georgia, serif;
  --font-sans:   'Inter', system-ui, sans-serif;
}

/* ─── BASE ───────────────────────────────────────────────── */
html {
  font-size: 20px;
}
body {
  font-family: var(--font-serif);
  background: var(--bg-void);
  color: var(--parchment);
  font-size: 22px;
  line-height: 1.7;
  -webkit-font-smoothing: antialiased;
}

/* ─── PAGE REVEAL ────────────────────────────────────────── */
@keyframes dawn {
  0%   { opacity: 0; }
  100% { opacity: 1; }
}
.site {
  animation: dawn 2.4s ease-in both;
}
@media (prefers-reduced-motion: reduce) {
  .site { animation: none; }
}

/* ─── UTILITIES ──────────────────────────────────────────── */
.wrap {
  max-width: 680px;
  margin: 0 auto;
  padding: 0 2.5rem;
}
.wrap--narrow {
  max-width: 560px;
  margin: 0 auto;
  padding: 0 2.5rem;
}
.label {
  display: block;
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 300;
  letter-spacing: 0.45em;
  text-transform: uppercase;
  color: var(--amber);
  margin-bottom: 2.5rem;
}
.rule {
  border: none;
  border-top: 1px solid var(--bg-earth);
  margin: 0;
}

/* ─── NAVIGATION ─────────────────────────────────────────── */
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--bg-deep);
  border-bottom: 1px solid var(--bg-earth);
  padding: 1.25rem 2.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.nav__logo {
  font-family: var(--font-serif);
  font-size: 20px;
  font-variant: small-caps;
  letter-spacing: 0.4em;
  color: var(--parchment);
}
.nav__links {
  display: flex;
  gap: 2rem;
  list-style: none;
}
.nav__links a {
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 300;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--faint);
  transition: color 0.3s;
}
.nav__links a:hover { color: var(--amber); }

.nav__menu-btn {
  display: none;
  flex-direction: column;
  gap: 5px;
  padding: 4px;
}
.nav__menu-btn span {
  display: block;
  width: 22px;
  height: 1px;
  background: var(--faint);
}

/* ─── HERO ───────────────────────────────────────────────── */
.hero {
  background: var(--bg-earth);
  min-height: 92vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 6rem 2.5rem 5rem;
  border-bottom: 3px solid var(--bg-surface);
}
.hero__origin {
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 300;
  letter-spacing: 0.5em;
  text-transform: uppercase;
  color: var(--ghost);
  margin-bottom: 2rem;
}
.hero__name {
  font-family: var(--font-serif);
  font-size: clamp(3.5rem, 10vw, 7rem);
  font-weight: 400;
  font-variant: small-caps;
  letter-spacing: 0.3em;
  color: var(--parchment);
  line-height: 1;
  margin-bottom: 2rem;
}
.hero__rule {
  width: 30px;
  height: 1px;
  background: var(--amber);
  margin: 0 auto 2rem;
}
.hero__quote {
  font-style: italic;
  font-size: 1.05rem;
  color: var(--muted);
  max-width: 640px;
  line-height: 1.9;
  margin-bottom: 3rem;
}
.hero__ctas {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  justify-content: center;
}
.btn {
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 400;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  padding: 0.8rem 2.25rem;
  transition: opacity 0.2s;
}
.btn:hover { opacity: 0.75; }
.btn--solid {
  background: var(--amber);
  color: var(--bg-void);
}
.btn--outline {
  border: 1px solid var(--faint);
  color: var(--faint);
}
.btn--outline:hover {
  border-color: var(--amber);
  color: var(--amber);
  opacity: 1;
}

/* ─── SECTIONS ───────────────────────────────────────────── */
.section {
  padding: 5.5rem 0;
}
.section--alt { background: var(--bg-surface); }
.section--deep { background: var(--bg-earth); }
.section--void { background: var(--bg-deep); }

/* ─── DISCOGRAFIA ────────────────────────────────────────── */
.albums {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
}
.album__cover {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  margin-bottom: 1.1rem;
}
.album__cover svg {
  width: 72%;
  height: 72%;
}
.album__title {
  font-size: 1.3rem;
  color: var(--parchment);
  margin-bottom: 0.25rem;
}
.album__meta {
  font-family: var(--font-sans);
  font-size: 15px;
  color: var(--ghost);
  letter-spacing: 0.12em;
  line-height: 1.8;
  margin-bottom: 0.6rem;
}
.album__link {
  font-family: var(--font-sans);
  font-size: 15px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--violet);
  border-bottom: 1px solid var(--violet);
  padding-bottom: 1px;
  display: inline-block;
  margin-bottom: 0.5rem;
  transition: color 0.2s, border-color 0.2s;
}
.album__link:hover { color: var(--parchment); border-color: var(--parchment); }

/* Pedra-Pão toggle */
.pedra-btn {
  display: block;
  font-family: var(--font-sans);
  font-size: 15px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--amber);
  border-bottom: 1px solid var(--amber);
  padding-bottom: 1px;
  margin-top: 0.4rem;
  transition: opacity 0.2s;
}
.pedra-btn:hover { opacity: 0.7; }

.pedra-panel {
  display: none;
  margin-top: 2rem;
  padding-top: 2rem;
  border-top: 1px solid var(--bg-earth);
  grid-column: 1 / -1;
}
.pedra-panel.is-open { display: block; }
.pedra-inner {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 2rem;
  align-items: start;
}
.pedra-cover {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.pedra-cover svg { width: 68%; height: 68%; }
.pedra-text {
  font-size: 0.95rem;
  color: var(--muted);
  line-height: 1.9;
  margin-bottom: 0.75rem;
}
.pedra-lyric {
  font-style: italic;
  font-size: 0.9rem;
  color: var(--faint);
  border-left: 2px solid var(--rust);
  padding-left: 0.85rem;
  margin-top: 1rem;
  line-height: 1.75;
}

.arc-note {
  font-style: italic;
  font-size: 0.95rem;
  color: var(--faint);
  text-align: center;
  margin-top: 2.5rem;
  line-height: 1.8;
}

/* ─── BANDO ──────────────────────────────────────────────── */
.bando-intro {
  font-size: 1.15rem;
  color: var(--muted);
  line-height: 1.95;
  margin-bottom: 2.5rem;
  max-width: 520px;
}
.bando-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.4rem 2.5rem;
}
.bando-member {
  font-size: 1rem;
  color: var(--faint);
  line-height: 1.9;
}
.bando-instrument {
  font-family: var(--font-sans);
  font-size: 15px;
  color: var(--ghost);
  display: block;
  letter-spacing: 0.05em;
}

.collab-label {
  font-family: var(--font-sans);
  font-size: 15px;
  font-weight: 300;
  letter-spacing: 0.4em;
  text-transform: uppercase;
  color: var(--ghost);
  margin: 2.5rem 0 1rem;
}
.collab-text {
  font-size: 0.95rem;
  color: var(--ghost);
  line-height: 1.85;
}
.collab-text em { color: var(--faint); font-style: normal; }

/* ─── AGENDA ─────────────────────────────────────────────── */
.show-list {
  border-top: 1px solid var(--bg-earth);
}
.show {
  display: grid;
  grid-template-columns: 110px 1fr auto;
  align-items: center;
  padding: 1rem 0;
  border-bottom: 1px solid var(--bg-earth);
  gap: 1rem;
}
.show__date {
  font-size: 0.95rem;
  color: var(--faint);
  font-style: italic;
}
.show__venue {
  font-size: 0.95rem;
  color: var(--parchment);
}
.show__city {
  font-family: var(--font-sans);
  font-size: 15px;
  color: var(--ghost);
  letter-spacing: 0.08em;
}
.show__cta {
  font-family: var(--font-sans);
  font-size: 15px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--violet);
  white-space: nowrap;
  transition: color 0.2s;
}
.show__cta:hover { color: var(--parchment); }
.show__cta--last { color: var(--amber); }
.show__cta--last:hover { color: var(--parchment); }

.agenda-note {
  font-style: italic;
  font-size: 0.9rem;
  color: var(--ghost);
  margin-top: 1.5rem;
}

/* ─── ARQUIVO ────────────────────────────────────────────── */
.press-list {
  border-top: 1px solid var(--bg-surface);
}
.press-item {
  padding: 1rem 0;
  border-bottom: 1px solid var(--bg-surface);
}
.press-item__src {
  font-family: var(--font-sans);
  font-size: 15px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ghost);
  margin-bottom: 0.3rem;
}
.press-item__title {
  font-size: 1rem;
  color: var(--muted);
  line-height: 1.55;
  transition: color 0.2s;
}
.press-item__title:hover { color: var(--parchment); }

/* ─── CONTACTO ───────────────────────────────────────────── */
.contact-heading {
  font-size: 2.25rem;
  font-weight: 400;
  color: var(--parchment);
  margin-bottom: 0.4rem;
}
.contact-sub {
  font-style: italic;
  font-size: 1rem;
  color: var(--faint);
  margin-bottom: 2.5rem;
}
.contact-block { margin-bottom: 1.75rem; }
.contact-key {
  font-family: var(--font-sans);
  font-size: 15px;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--ghost);
  margin-bottom: 0.35rem;
}
.contact-val {
  font-size: 1.05rem;
  color: var(--violet);
  display: block;
  transition: color 0.2s;
}
.contact-val:hover { color: var(--parchment); }
.socials {
  display: flex;
  gap: 2rem;
  flex-wrap: wrap;
}
.socials a {
  font-family: var(--font-sans);
  font-size: 15px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--ghost);
  transition: color 0.2s;
}
.socials a:hover { color: var(--amber); }

/* ─── FOOTER ─────────────────────────────────────────────── */
.footer {
  background: var(--bg-void);
  border-top: 1px solid var(--bg-deep);
  padding: 1.5rem 2.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.footer__copy {
  font-family: var(--font-sans);
  font-size: 15px;
  letter-spacing: 0.18em;
  color: var(--ghost);
}
.footer__tag {
  font-style: italic;
  font-size: 17px;
  color: var(--ghost);
}
.footer__link {
  font-family: var(--font-sans);
  font-size: 13px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--ghost);
  transition: color 0.2s;
}
.footer__link:hover { color: var(--amber); }

/* ─── MOBILE ─────────────────────────────────────────────── */
@media (max-width: 640px) {
  .nav__links { display: none; }
  .nav__links.is-open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--bg-deep);
    padding: 1.5rem 2rem;
    border-bottom: 1px solid var(--bg-earth);
    gap: 1.25rem;
    z-index: 99;
  }
  .nav { position: relative; }
  .nav__menu-btn { display: flex; }

  .hero__name { font-size: clamp(2.8rem, 14vw, 5rem); }
  .albums { grid-template-columns: 1fr; gap: 2.5rem; }
  .pedra-inner { grid-template-columns: 1fr; }
  .bando-grid { grid-template-columns: 1fr; }
  .show { grid-template-columns: 90px 1fr; }
  .show__cta { display: none; }
  .wrap, .wrap--narrow { padding: 0 1.25rem; }
  .nav { padding: 1.1rem 1.25rem; }
  .footer { padding: 1.25rem; flex-direction: column; gap: 0.5rem; text-align: center; }
  #videos .wrap > div { grid-template-columns: 1fr !important; }
  #a-banda [style*="repeat(5"] { grid-template-columns: repeat(2, 1fr) !important; }
}
    </style>
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4QWBP7V76E"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4QWBP7V76E');
    </script>
  </head>
  <body>
    <div class="site">
      <slot />
    </div>
    <script>
      // Mobile nav toggle
      const menuBtn = document.getElementById('menu-btn');
      const navLinks = document.getElementById('nav-links');
      menuBtn.addEventListener('click', () => {
        const isOpen = navLinks.classList.toggle('is-open');
        menuBtn.setAttribute('aria-expanded', isOpen);
      });
      // Close mobile nav on link click
      navLinks.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          navLinks.classList.remove('is-open');
          menuBtn.setAttribute('aria-expanded', false);
        });
      });

      // Pedra-Pão toggle
      const pedraBtn = document.getElementById('pedra-btn');
      const pedraPanel = document.getElementById('pedra-panel');
      pedraBtn.addEventListener('click', () => {
        const isOpen = pedraPanel.classList.toggle('is-open');
        pedraBtn.setAttribute('aria-expanded', isOpen);
        pedraBtn.textContent = isOpen ? '← Fechar a Pedra-Pão' : 'A Pedra-Pão →';
        if (isOpen) {
          pedraPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      });

      // Active nav link on scroll
      const sections = document.querySelectorAll('section[id]');
      const navAnchors = document.querySelectorAll('.nav__links a');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            navAnchors.forEach(a => {
              a.style.color = a.getAttribute('href') === '#' + entry.target.id
                ? 'var(--amber)' : '';
            });
          }
        });
      }, { threshold: 0.3 });
      sections.forEach(s => observer.observe(s));
    </script>
  </body>
</html>
